{
  "name": "kubesimplify-website",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/generate-feeds.mjs && node scripts/generate-redirects.mjs",
    "build": "next build && pagefind --site out --output-subdir pagefind",
    "start": "next start",
    "lint": "next lint",
    "blog:import": "node scripts/import-posts.mjs",
    "blog:images": "node scripts/download-images.mjs",
    "blog:feeds": "node scripts/generate-feeds.mjs",
    "blog:redirects": "node scripts/generate-redirects.mjs"
  },
  "dependencies": {
    "framer-motion": "^11.18.0",
    "gray-matter": "^4.0.3",
    "next": "^14.2.21",
    "next-mdx-remote": "^4.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "reading-time": "^1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.12.6",
    "rehype-raw": "^7.0.0",
    "rehype-react": "^8.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^1.29.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "pagefind": "^1.5.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  }
}
